{
  "name": "screen-plus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/fix-node-pty.cjs",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.cjs",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server/index.cjs"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.12.0-beta.287",
    "@xterm/xterm": "^6.1.0-beta.287",
    "express": "^4.19.2",
    "node-pty": "^1.0.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^8.1.0"
  },
  "license": "GPL-3.0-or-later"
}
